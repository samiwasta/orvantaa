# Neon (pooled) — use for app runtime / Prisma Client
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Neon (direct) — use for Prisma migrations
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth (generate with: openssl rand -base64 32)
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN_SECONDS="604800"

# Email provider: "resend" (default) | "ses"
EMAIL_PROVIDER="resend"
EMAIL_FROM="Orvantaa <noreply@orvantaa.com>"

# Resend (https://resend.com/api-keys)
RESEND_API_KEY="re_..."

# App URL — used to build reset-password links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
